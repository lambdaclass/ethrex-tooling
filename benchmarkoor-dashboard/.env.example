# Copy this file to .env (gitignored) and set your key. The dashboard reads the
# key from the process env, then from this local .env.
#
BENCHMARKOOR_API_BASE=https://benchmarkoor-api.core.ethpandaops.io
BENCHMARKOOR_API_KEY=bmk_your_key_here
#
# Optional tuning:
# DASH_DB_PATH=data/benchmarkoor.db
# DASH_ACTIVE_WINDOW_DAYS=7
# DASH_HOME_CLIENT=ethrex
